{
  "openapi": "3.0.3",
  "info": {
    "title": "XAccel 控制面 - 业务后台对接 API",
    "description": "业务后台调用控制面的专用接口。游戏、区服、线路主数据由业务后台维护；控制面只保存调度和节点执行副本。导入 Apifox 后请在环境变量中配置 baseUrl 和 XACCEL_BUSINESS_SYNC_TOKEN。所有业务接口都需要鉴权，推荐使用 Authorization: Bearer <Token>。",
    "version": "0.56.0"
  },
  "servers": [
    {
      "url": "{{baseUrl}}",
      "description": "Apifox 环境变量，示例：http://103.201.131.99:18080"
    },
    {
      "url": "http://103.201.131.99:18080",
      "description": "当前控制面公网地址"
    },
    {
      "url": "http://127.0.0.1:18080",
      "description": "控制面本机调试地址"
    }
  ],
  "tags": [
    {
      "name": "业务后台对接",
      "description": "业务后台同步游戏/区服/线路、签发 connect-intent、检查控制面状态。"
    }
  ],
  "paths": {
    "/api/business/v1/status": {
      "get": {
        "tags": [
          "业务后台对接"
        ],
        "summary": "业务 API 状态检查",
        "description": "业务后台启动或定时探活时调用。需要业务后台 Token。\n\n鉴权：推荐在请求头传 Authorization: Bearer {{XACCEL_BUSINESS_SYNC_TOKEN}}；也兼容 X-Business-Sync-Token: {{XACCEL_BUSINESS_SYNC_TOKEN}}。",
        "operationId": "businessStatus",
        "security": [
          {
            "BusinessBearerAuth": []
          },
          {
            "BusinessSyncTokenHeader": []
          }
        ],
        "responses": {
          "200": {
            "description": "控制面业务 API 可用",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BusinessStatusResponse"
                },
                "example": {
                  "status": "ok",
                  "version": "0.56.0",
                  "catalog_owner": "business_backend",
                  "control_role": "node_operations",
                  "business_api_enabled": true,
                  "nodes_total": 2,
                  "nodes_online": 2,
                  "games_enabled": 1,
                  "routes_enabled": 2,
                  "server_time": 1781070000
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/business/v1/sync-catalog": {
      "post": {
        "tags": [
          "业务后台对接"
        ],
        "summary": "同步游戏、区服和线路",
        "description": "业务后台把游戏、区服、线路的执行副本同步到控制面。日常新增、编辑、下线游戏/区服/线路都应该从业务后台发起。支持分步同步：可以只传 games、只传 regions、只传 route_rules，也可以一次全量传。未传的数据不会被删除，下线请传 status=disabled。\n\n鉴权：推荐在请求头传 Authorization: Bearer {{XACCEL_BUSINESS_SYNC_TOKEN}}；也兼容 X-Business-Sync-Token: {{XACCEL_BUSINESS_SYNC_TOKEN}}。",
        "operationId": "businessSyncCatalog",
        "security": [
          {
            "BusinessBearerAuth": []
          },
          {
            "BusinessSyncTokenHeader": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BusinessSyncCatalogRequest"
              },
              "example": {
                "source": "business-admin",
                "revision": "2026-06-10T11:40:00+08:00",
                "games": [
                  {
                    "game_id": 8888,
                    "name": "本地 UDP 测试",
                    "platform": "pc",
                    "category": "test",
                    "status": "enabled",
                    "remark": "联调用游戏"
                  }
                ],
                "regions": [
                  {
                    "game_id": 8888,
                    "region_id": 1,
                    "name": "默认区服",
                    "area": "HK",
                    "status": "enabled",
                    "remark": "默认线路"
                  }
                ],
                "route_rules": [
                  {
                    "external_id": "route-8888-hk-node2",
                    "game_id": 8888,
                    "game_name": "本地 UDP 测试",
                    "region_id": 1,
                    "region_name": "默认区服",
                    "node_id": 2,
                    "target_addr": "127.0.0.1:7777",
                    "protocol": "udp",
                    "area": "HK",
                    "tag": "default",
                    "priority": 10,
                    "status": "enabled"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "同步完成",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BusinessSyncCatalogResponse"
                },
                "example": {
                  "status": "ok",
                  "source": "business-admin",
                  "revision": "2026-06-10T11:40:00+08:00",
                  "games_upserted": 1,
                  "regions_upserted": 1,
                  "route_rules_upserted": 1,
                  "server_time": 1781070000
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/business/v1/connect-intent": {
      "post": {
        "tags": [
          "业务后台对接"
        ],
        "summary": "业务后台签发加速意图",
        "description": "业务后台完成登录、套餐、设备和游戏权限校验后调用。控制面返回候选节点、节点 token 和路由目标。客户端拿到候选节点后再连接节点，不直接访问控制面管理接口。\n\n鉴权：推荐在请求头传 Authorization: Bearer {{XACCEL_BUSINESS_SYNC_TOKEN}}；也兼容 X-Business-Sync-Token: {{XACCEL_BUSINESS_SYNC_TOKEN}}。",
        "operationId": "businessConnectIntent",
        "security": [
          {
            "BusinessBearerAuth": []
          },
          {
            "BusinessSyncTokenHeader": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BusinessConnectIntentRequest"
              },
              "example": {
                "request_id": "req-20260610-0001",
                "entitlement_id": "vip-order-1001",
                "user_id": 1001,
                "device_id": "pc-001",
                "game_id": 8888,
                "region_id": 1,
                "platform": "pc",
                "client_isp": "telecom",
                "client_ip": "127.0.0.1",
                "bandwidth_quality": "fast",
                "client_version": "0.1.0"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "签发成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BusinessConnectIntentResponse"
                },
                "example": {
                  "status": "ok",
                  "request_id": "req-20260610-0001",
                  "entitlement_id": "vip-order-1001",
                  "client_version": "0.1.0",
                  "connect_intent": {
                    "intent_id": "intent-1001-8888-1781070000-2",
                    "ttl_sec": 120,
                    "client": {
                      "platform": "pc",
                      "client_isp": "telecom",
                      "client_ip": "127.0.0.1",
                      "bandwidth_quality": "fast",
                      "region_id": 1
                    },
                    "candidates": [
                      {
                        "node_id": 2,
                        "area": "HK",
                        "tag": "default",
                        "host": "47.83.160.126",
                        "port": 666,
                        "transports": [
                          "udp"
                        ],
                        "bandwidth_quality": "normal",
                        "probe": {
                          "udp": true,
                          "tcp": true,
                          "protocol": "xaccel/1"
                        },
                        "route": {
                          "target_addr": "127.0.0.1:7777",
                          "protocol": "udp",
                          "region_id": 1,
                          "region_name": "默认区服"
                        },
                        "credential": {
                          "token": "xat.v1.xxx",
                          "expires_at": 1781070120,
                          "intent_id": "intent-1001-8888-1781070000-2",
                          "route": {
                            "target_addr": "127.0.0.1:7777",
                            "protocol": "udp",
                            "region_id": 1,
                            "region_name": "默认区服"
                          }
                        },
                        "scheduler": {
                          "route_priority": 10,
                          "latest_active_sessions": 0,
                          "latest_udp_sessions": 0,
                          "latest_tcp_sessions": 0,
                          "latest_reported_at": 1781069990,
                          "latest_report_age_sec": 10,
                          "report_fresh": true
                        }
                      }
                    ]
                  },
                  "server_time": 1781070000
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NoCandidate"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BusinessBearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "XACCEL_BUSINESS_SYNC_TOKEN",
        "description": "推荐方式：Authorization: Bearer <业务后台 Token>"
      },
      "BusinessSyncTokenHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Business-Sync-Token",
        "description": "兼容方式：X-Business-Sync-Token: <业务后台 Token>"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "请求参数错误",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": {
                "code": "invalid_game",
                "message": "game_id is invalid"
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "业务后台 Token 缺失或错误",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "required": {
                "summary": "未传 Token",
                "value": {
                  "error": {
                    "code": "business_sync_auth_required",
                    "message": "business sync token is required"
                  }
                }
              },
              "failed": {
                "summary": "Token 错误",
                "value": {
                  "error": {
                    "code": "business_sync_auth_failed",
                    "message": "business sync token is invalid"
                  }
                }
              }
            }
          }
        }
      },
      "NoCandidate": {
        "description": "没有可用候选节点或路由",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": {
                "code": "no_candidate",
                "message": "no available node candidate"
              }
            }
          }
        }
      },
      "InternalError": {
        "description": "控制面内部错误",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": {
                "code": "internal_error",
                "message": "database operation failed"
              }
            }
          }
        }
      }
    },
    "schemas": {
      "BusinessStatusResponse": {
        "type": "object",
        "required": [
          "status",
          "version",
          "catalog_owner",
          "control_role",
          "business_api_enabled",
          "nodes_total",
          "nodes_online",
          "games_enabled",
          "routes_enabled",
          "server_time"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "ok",
            "description": "接口调用结果。ok 表示控制面业务 API 可用。"
          },
          "version": {
            "type": "string",
            "example": "0.56.0",
            "description": "控制面当前版本号，用于业务后台记录兼容版本。"
          },
          "catalog_owner": {
            "type": "string",
            "enum": [
              "business_backend"
            ],
            "description": "游戏、区服、线路主数据归属。固定为 business_backend，表示业务后台是主入口。",
            "example": "business_backend"
          },
          "control_role": {
            "type": "string",
            "enum": [
              "node_operations"
            ],
            "description": "控制面职责。固定为 node_operations，表示控制面只负责节点运维、调度和执行副本。",
            "example": "node_operations"
          },
          "business_api_enabled": {
            "type": "boolean",
            "description": "业务 API Token 是否已配置。false 时业务后台不能正常调用受保护接口。",
            "example": true
          },
          "nodes_total": {
            "type": "integer",
            "format": "uint64",
            "description": "控制面节点总数。",
            "example": 2
          },
          "nodes_online": {
            "type": "integer",
            "format": "uint64",
            "description": "当前在线节点数量。业务后台可用来判断是否有可调度资源。",
            "example": 2
          },
          "games_enabled": {
            "type": "integer",
            "format": "uint64",
            "description": "控制面执行副本里启用中的游戏数量，来自业务后台同步。",
            "example": 1
          },
          "routes_enabled": {
            "type": "integer",
            "format": "uint64",
            "description": "控制面执行副本里启用中的线路数量，connect-intent 依赖这里的数据。",
            "example": 2
          },
          "server_time": {
            "type": "integer",
            "format": "uint64",
            "description": "控制面 Unix 秒级时间戳，用于日志对齐和过期时间判断。",
            "example": 1781070000
          }
        }
      },
      "BusinessSyncCatalogRequest": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string",
            "maxLength": 64,
            "default": "business",
            "description": "同步来源标识。建议填业务后台服务名，例如 business-admin、xboard、billing-api。为空时控制面默认 business。",
            "example": "business-admin"
          },
          "revision": {
            "type": "string",
            "maxLength": 128,
            "description": "业务后台本次同步版本号，可填业务数据版本、发布时间或 ISO 时间。用于排查本次同步来自哪个批次。",
            "example": "2026-06-10T11:40:00+08:00"
          },
          "games": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BusinessSyncGame"
            },
            "default": [],
            "description": "游戏列表。可单独只传 games，接口会按 game_id upsert，不会删除未传的旧游戏。"
          },
          "regions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BusinessSyncRegion"
            },
            "default": [],
            "description": "区服列表。可单独只传 regions，接口会按 game_id + region_id upsert，不会删除未传的旧区服。"
          },
          "route_rules": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BusinessSyncRouteRule"
            },
            "default": [],
            "description": "线路规则列表。可单独只传 route_rules，接口会按 source + external_id 或默认唯一键 upsert，不会删除未传的旧线路。也兼容字段名 routes。"
          }
        }
      },
      "BusinessSyncGame": {
        "type": "object",
        "required": [
          "game_id",
          "name"
        ],
        "properties": {
          "game_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1,
            "description": "业务后台游戏 ID。必须全局稳定，客户端 connect-intent 也使用这个 ID。",
            "example": 8888
          },
          "name": {
            "type": "string",
            "maxLength": 128,
            "description": "游戏名称，控制面只用于快照展示和排查。",
            "example": "英雄联盟"
          },
          "platform": {
            "type": "string",
            "enum": [
              "pc",
              "android",
              "ios",
              "multi"
            ],
            "default": "pc",
            "description": "游戏平台。pc=电脑端，android=安卓，ios=苹果，multi=多端。为空默认 pc。",
            "example": "pc"
          },
          "category": {
            "type": "string",
            "maxLength": 64,
            "description": "游戏分类，可填 moba、fps、rpg、test 等，控制面只展示不参与调度。",
            "example": "moba"
          },
          "icon_url": {
            "type": "string",
            "format": "uri",
            "maxLength": 512,
            "description": "游戏图标 URL，可选。控制面当前只保存，后续业务后台或客户端可复用。",
            "example": "https://example.com/icons/lol.png"
          },
          "status": {
            "type": "string",
            "enum": [
              "enabled",
              "disabled"
            ],
            "default": "enabled",
            "description": "游戏状态。enabled=启用，disabled=停用。停用后不建议继续签发 connect-intent。",
            "example": "enabled"
          },
          "remark": {
            "type": "string",
            "maxLength": 512,
            "description": "备注，可记录业务说明、测试说明或同步来源。",
            "example": "正式游戏"
          }
        }
      },
      "BusinessSyncRegion": {
        "type": "object",
        "required": [
          "game_id",
          "region_id",
          "name"
        ],
        "properties": {
          "game_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1,
            "description": "所属游戏 ID，必须对应 games 中的 game_id。",
            "example": 8888
          },
          "region_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1,
            "description": "业务后台区服 ID。同一个游戏下稳定唯一。客户端选择区服后传给 connect-intent。",
            "example": 1
          },
          "name": {
            "type": "string",
            "maxLength": 128,
            "description": "区服名称，例如电信一区、华东一区、默认区服。",
            "example": "电信一区"
          },
          "area": {
            "type": "string",
            "maxLength": 64,
            "description": "区服或线路区域标识，例如 HK、JP、CN-EAST。控制面用于展示和后续调度扩展。",
            "example": "HK"
          },
          "status": {
            "type": "string",
            "enum": [
              "enabled",
              "disabled"
            ],
            "default": "enabled",
            "description": "区服状态。enabled=启用，disabled=停用。",
            "example": "enabled"
          },
          "remark": {
            "type": "string",
            "maxLength": 512,
            "description": "区服备注。",
            "example": "香港入口默认区服"
          }
        }
      },
      "BusinessSyncRouteRule": {
        "type": "object",
        "required": [
          "game_id",
          "node_id",
          "target_addr"
        ],
        "properties": {
          "external_id": {
            "type": "string",
            "maxLength": 128,
            "description": "业务后台线路唯一 ID。强烈建议传入并保持稳定，后续编辑同一线路时复用它，避免重复插入。",
            "example": "route-8888-hk-node2"
          },
          "game_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1,
            "description": "所属游戏 ID。connect-intent 会按 game_id 查找启用线路。",
            "example": 8888
          },
          "game_name": {
            "type": "string",
            "maxLength": 128,
            "description": "游戏名称快照。可选；传入后控制面路由列表展示更清楚。",
            "example": "英雄联盟"
          },
          "region_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1,
            "description": "所属区服 ID。可选；传入后 connect-intent 可按指定区服调度线路。",
            "example": 1
          },
          "region_name": {
            "type": "string",
            "maxLength": 128,
            "description": "区服名称快照。可选。",
            "example": "电信一区"
          },
          "node_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1,
            "description": "控制面节点 ID。必须是控制面已有节点，业务后台可以从节点列表或运维配置里拿到。",
            "example": 2
          },
          "target_addr": {
            "type": "string",
            "maxLength": 255,
            "example": "127.0.0.1:7777",
            "description": "节点要转发到的游戏目标地址，格式 host:port。MVP 通常是 UDP 目标。"
          },
          "protocol": {
            "type": "string",
            "enum": [
              "udp",
              "tcp"
            ],
            "default": "udp",
            "description": "转发协议。当前主要使用 udp；tcp 为预留/兼容。为空默认 udp。",
            "example": "udp"
          },
          "area": {
            "type": "string",
            "maxLength": 64,
            "description": "线路区域标识。可用于展示和后续同区域优先调度。",
            "example": "HK"
          },
          "tag": {
            "type": "string",
            "maxLength": 64,
            "description": "线路标签，例如 default、premium、backup。控制面用于展示和后续策略扩展。",
            "example": "default"
          },
          "priority": {
            "type": "integer",
            "format": "uint32",
            "default": 100,
            "description": "线路优先级，数字越小越优先。同游戏同区服多条线路时用于排序。为空默认 100。",
            "example": 10
          },
          "status": {
            "type": "string",
            "enum": [
              "enabled",
              "disabled"
            ],
            "default": "enabled",
            "description": "线路状态。enabled=启用参与调度，disabled=停用不参与调度。删除/下线建议传 disabled。",
            "example": "enabled"
          }
        }
      },
      "BusinessSyncCatalogResponse": {
        "type": "object",
        "required": [
          "status",
          "source",
          "games_upserted",
          "regions_upserted",
          "route_rules_upserted",
          "server_time"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "ok",
            "description": "同步结果。ok 表示本次 upsert 已完成。"
          },
          "source": {
            "type": "string",
            "description": "本次同步来源，来自请求 source 或默认 business。",
            "example": "business-admin"
          },
          "revision": {
            "type": "string",
            "nullable": true,
            "description": "本次同步版本，原样返回请求 revision；为空时为 null。",
            "example": "2026-06-10T11:40:00+08:00"
          },
          "games_upserted": {
            "type": "integer",
            "format": "uint64",
            "description": "本次新增或更新的游戏数量。",
            "example": 1
          },
          "regions_upserted": {
            "type": "integer",
            "format": "uint64",
            "description": "本次新增或更新的区服数量。",
            "example": 1
          },
          "route_rules_upserted": {
            "type": "integer",
            "format": "uint64",
            "description": "本次新增或更新的线路数量。",
            "example": 1
          },
          "server_time": {
            "type": "integer",
            "format": "uint64",
            "description": "控制面 Unix 秒级时间戳。",
            "example": 1781070000
          }
        }
      },
      "BusinessConnectIntentRequest": {
        "type": "object",
        "required": [
          "user_id",
          "device_id",
          "game_id"
        ],
        "properties": {
          "request_id": {
            "type": "string",
            "maxLength": 128,
            "description": "业务后台请求流水号。建议每次请求唯一，便于排查客户端、业务后台、控制面的日志。",
            "example": "req-20260610-0001"
          },
          "entitlement_id": {
            "type": "string",
            "maxLength": 128,
            "description": "权益/订单/套餐/加速卡 ID。控制面原样记录和返回，便于追踪，不负责校验权益。",
            "example": "vip-order-1001"
          },
          "user_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1,
            "description": "业务后台用户 ID。控制面用于签发节点 token，不负责判断是否会员。",
            "example": 1001
          },
          "device_id": {
            "type": "string",
            "maxLength": 128,
            "description": "客户端设备 ID。业务后台应先完成设备限制校验，控制面会写入节点 token。",
            "example": "pc-001"
          },
          "game_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1,
            "description": "要加速的游戏 ID，必须已有启用线路。",
            "example": 8888
          },
          "region_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1,
            "description": "可选区服 ID。传入后优先匹配该区服线路；不传则按游戏维度调度。",
            "example": 1
          },
          "platform": {
            "type": "string",
            "enum": [
              "pc",
              "android",
              "ios",
              "multi"
            ],
            "description": "客户端平台。pc=电脑端，android=安卓，ios=苹果，multi=多端。",
            "example": "pc"
          },
          "client_isp": {
            "type": "string",
            "enum": [
              "telecom",
              "unicom",
              "mobile",
              "other"
            ],
            "description": "客户端运营商。telecom=电信，unicom=联通，mobile=移动，other=其它。用于后续 ISP 调度。",
            "example": "telecom"
          },
          "client_ip": {
            "type": "string",
            "description": "客户端公网 IP。建议由业务后台从请求侧可信获取，不要完全信任客户端自报。",
            "example": "127.0.0.1"
          },
          "bandwidth_quality": {
            "type": "string",
            "enum": [
              "fast",
              "normal",
              "slow"
            ],
            "default": "normal",
            "description": "客户端期望线路质量。fast=优先快线，normal=普通，slow=低成本/兜底。为空默认 normal。",
            "example": "fast"
          },
          "client_version": {
            "type": "string",
            "maxLength": 64,
            "description": "客户端版本号。控制面原样返回，方便灰度和日志排查。",
            "example": "0.1.0"
          }
        }
      },
      "BusinessConnectIntentResponse": {
        "type": "object",
        "required": [
          "status",
          "connect_intent",
          "server_time"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "ok",
            "description": "签发结果。ok 表示已返回可用候选节点。"
          },
          "request_id": {
            "type": "string",
            "nullable": true,
            "description": "请求里的 request_id 原样返回。",
            "example": "req-20260610-0001"
          },
          "entitlement_id": {
            "type": "string",
            "nullable": true,
            "description": "请求里的 entitlement_id 原样返回。",
            "example": "vip-order-1001"
          },
          "client_version": {
            "type": "string",
            "nullable": true,
            "description": "请求里的 client_version 原样返回。",
            "example": "0.1.0"
          },
          "connect_intent": {
            "$ref": "#/components/schemas/ConnectIntent",
            "description": "控制面签发的加速意图，客户端使用 candidates 里的节点地址和 token 连接节点。"
          },
          "server_time": {
            "type": "integer",
            "format": "uint64",
            "description": "控制面 Unix 秒级时间戳。",
            "example": 1781070000
          }
        }
      },
      "ConnectIntent": {
        "type": "object",
        "required": [
          "intent_id",
          "ttl_sec",
          "client",
          "candidates"
        ],
        "properties": {
          "intent_id": {
            "type": "string",
            "description": "本次加速意图 ID。节点 token 和后续日志会关联这个 ID。",
            "example": "intent-1001-8888-1781070000-2"
          },
          "ttl_sec": {
            "type": "integer",
            "format": "uint64",
            "description": "加速意图有效期秒数。客户端应在有效期内发起节点 probe。",
            "example": 120
          },
          "client": {
            "$ref": "#/components/schemas/ClientContext",
            "description": "本次请求的客户端上下文。"
          },
          "candidates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NodeCandidate"
            },
            "description": "候选节点列表，按调度优先级排序。客户端一般优先尝试第一个，失败后可尝试下一个。"
          }
        }
      },
      "ClientContext": {
        "type": "object",
        "required": [
          "bandwidth_quality"
        ],
        "properties": {
          "platform": {
            "type": "string",
            "nullable": true,
            "description": "客户端平台，来自请求 platform。",
            "example": "pc"
          },
          "client_isp": {
            "type": "string",
            "nullable": true,
            "description": "客户端运营商，来自请求 client_isp。",
            "example": "telecom"
          },
          "client_ip": {
            "type": "string",
            "nullable": true,
            "description": "客户端公网 IP，来自请求 client_ip。",
            "example": "127.0.0.1"
          },
          "bandwidth_quality": {
            "type": "string",
            "enum": [
              "fast",
              "normal",
              "slow"
            ],
            "description": "本次调度使用的线路质量偏好。",
            "example": "fast"
          },
          "region_id": {
            "type": "integer",
            "format": "uint64",
            "nullable": true,
            "description": "本次调度指定的区服 ID；没有指定时为 null。",
            "example": 1
          }
        }
      },
      "NodeCandidate": {
        "type": "object",
        "required": [
          "node_id",
          "area",
          "tag",
          "host",
          "port",
          "transports",
          "bandwidth_quality",
          "probe",
          "route",
          "credential",
          "scheduler"
        ],
        "properties": {
          "node_id": {
            "type": "integer",
            "format": "uint64",
            "description": "控制面节点 ID。",
            "example": 2
          },
          "area": {
            "type": "string",
            "description": "节点区域，例如 HK、JP、US。",
            "example": "HK"
          },
          "tag": {
            "type": "string",
            "description": "节点标签，例如 default、premium、standalone。",
            "example": "default"
          },
          "host": {
            "type": "string",
            "description": "客户端连接节点使用的公网 IP 或域名。",
            "example": "47.83.160.126"
          },
          "port": {
            "type": "integer",
            "format": "uint16",
            "minimum": 1,
            "maximum": 65535,
            "description": "客户端连接节点使用的入口端口。",
            "example": 666
          },
          "transports": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "udp",
                "tcp"
              ]
            },
            "description": "候选节点支持的传输协议。当前主要使用 udp。",
            "example": [
              "udp"
            ]
          },
          "bandwidth_quality": {
            "type": "string",
            "enum": [
              "fast",
              "normal",
              "slow"
            ],
            "description": "节点带宽质量标记。",
            "example": "normal"
          },
          "probe": {
            "$ref": "#/components/schemas/ProbeInfo",
            "description": "客户端可用的探测能力。"
          },
          "route": {
            "$ref": "#/components/schemas/ClientRoute",
            "description": "该候选节点绑定的转发目标。"
          },
          "credential": {
            "$ref": "#/components/schemas/CredentialInfo",
            "description": "客户端连接节点使用的短期凭证。"
          },
          "scheduler": {
            "$ref": "#/components/schemas/CandidateSchedulerInfo",
            "description": "调度器选择该节点时参考的指标，便于业务后台排查为什么选中该节点。"
          }
        }
      },
      "ProbeInfo": {
        "type": "object",
        "required": [
          "udp",
          "tcp",
          "protocol"
        ],
        "properties": {
          "udp": {
            "type": "boolean",
            "description": "是否支持 UDP probe。",
            "example": true
          },
          "tcp": {
            "type": "boolean",
            "description": "是否支持 TCP probe。",
            "example": true
          },
          "protocol": {
            "type": "string",
            "example": "xaccel/1",
            "description": "节点探测协议版本。"
          }
        }
      },
      "ClientRoute": {
        "type": "object",
        "required": [
          "target_addr",
          "protocol"
        ],
        "properties": {
          "target_addr": {
            "type": "string",
            "example": "127.0.0.1:7777",
            "description": "节点最终转发到的游戏目标地址。客户端不用直连该地址。"
          },
          "protocol": {
            "type": "string",
            "enum": [
              "udp",
              "tcp"
            ],
            "description": "目标转发协议。",
            "example": "udp"
          },
          "region_id": {
            "type": "integer",
            "format": "uint64",
            "nullable": true,
            "description": "该路由所属区服 ID；无区服时为 null。",
            "example": 1
          },
          "region_name": {
            "type": "string",
            "nullable": true,
            "description": "该路由所属区服名称；无区服时为 null。",
            "example": "电信一区"
          }
        }
      },
      "CredentialInfo": {
        "type": "object",
        "required": [
          "token",
          "expires_at",
          "intent_id",
          "route"
        ],
        "properties": {
          "token": {
            "type": "string",
            "description": "客户端连接节点时使用的短期 xat.v1 token。业务后台只转发给客户端，不应长期保存。",
            "example": "xat.v1.xxx"
          },
          "expires_at": {
            "type": "integer",
            "format": "uint64",
            "description": "节点 token 过期时间，Unix 秒级时间戳。",
            "example": 1781070120
          },
          "intent_id": {
            "type": "string",
            "description": "该 token 绑定的加速意图 ID。",
            "example": "intent-1001-8888-1781070000-2"
          },
          "route": {
            "$ref": "#/components/schemas/ClientRoute",
            "description": "token 内绑定的路由目标。节点会校验 token 中的 route，防止客户端改目标。"
          }
        }
      },
      "CandidateSchedulerInfo": {
        "type": "object",
        "required": [
          "route_priority",
          "latest_active_sessions",
          "latest_udp_sessions",
          "latest_tcp_sessions",
          "report_fresh"
        ],
        "properties": {
          "route_priority": {
            "type": "integer",
            "format": "uint32",
            "description": "线路优先级，数字越小越优先。",
            "example": 10
          },
          "latest_active_sessions": {
            "type": "integer",
            "format": "uint32",
            "description": "节点最近一次上报的活跃会话数。",
            "example": 0
          },
          "latest_udp_sessions": {
            "type": "integer",
            "format": "uint32",
            "description": "节点最近一次上报的活跃 UDP 会话数。",
            "example": 0
          },
          "latest_tcp_sessions": {
            "type": "integer",
            "format": "uint32",
            "description": "节点最近一次上报的活跃 TCP 会话数。",
            "example": 0
          },
          "latest_reported_at": {
            "type": "integer",
            "format": "uint64",
            "nullable": true,
            "description": "节点最近一次上报时间，Unix 秒级时间戳；没有上报时为 null。",
            "example": 1781069990
          },
          "latest_report_age_sec": {
            "type": "integer",
            "format": "uint64",
            "nullable": true,
            "description": "最近一次上报距当前的秒数；没有上报时为 null。",
            "example": 10
          },
          "report_fresh": {
            "type": "boolean",
            "description": "节点上报是否新鲜。true 表示近期有上报，调度可信度更高。",
            "example": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "object",
            "required": [
              "code",
              "message"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "机器可读错误码，例如 business_sync_auth_failed、invalid_game、no_candidate。",
                "example": "no_candidate"
              },
              "message": {
                "type": "string",
                "description": "人类可读错误说明，主要用于日志和联调排查。",
                "example": "no available node candidate"
              }
            },
            "description": "统一错误对象。业务后台应优先读取 error.code 做逻辑判断，再把 message 用于日志或调试。"
          }
        }
      }
    }
  }
}
